# ─── AdSense ───────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-1971729858495340
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_POST_HERO=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE_2=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_SIDEBAR=

# ─── Seguridad del CRON ────────────────────────────────────
# Secreto para disparar el cron manualmente: Authorization: Bearer <valor>
CRON_SECRET=

# ─── Base de datos (opcional pero recomendado) ─────────────
# Sin DB se usa almacenamiento en archivo local (.local-data/drafts.json)
# Con DB se habilitan locks distribuidos y panel de revisión completo
DATABASE_URL=

# ─── EXA (fuente primaria de noticias) ─────────────────────
EXA_API_KEY=
# ID de un Webset existente (opcional — si está vacío se crea uno nuevo)
EXA_WEBSET_ID=
# Forzar modo: "search" usa búsqueda directa en lugar de Websets
EXA_MODE=auto

# ─── Fuentes adicionales (todas opcionales) ─────────────────
# NewsAPI.org — plan gratuito: 100 req/día
# https://newsapi.org/register
NEWS_API_KEY=

# GNews.io — plan gratuito: 100 req/día, hasta 10 artículos por request
# https://gnews.io/
GNEWS_API_KEY=

# ─── IA para redacción ────────────────────────────────────
# OpenRouter — compatible con cientos de modelos
# https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.5
OPENROUTER_SITE_URL=https://copamundial.today/
OPENROUTER_APP_NAME=CopaMundial2026

# ─── Panel de operaciones (/ops) ──────────────────────────
OPS_PASSWORD=
